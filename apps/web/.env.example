# ──────────────────────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env.local AND FILL IN YOUR REAL VALUES
# NEVER commit .env.local to version control
# ──────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key — NEVER expose to frontend
# Used only in Server Actions and Route Handlers
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Maps ───────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
#
# Key 1 — Browser (Maps JavaScript API + Places API)
#   Restriction: HTTP referrer → your domains
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...
#
# Key 2 — Servidor (Routes API + Geocoding API)
#   Restriction: API restriction only (NO referrer) — NEVER use NEXT_PUBLIC_
GOOGLE_MAPS_SERVER_KEY=AIzaSy...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-base64-key-here

# ── Rate limiting (Upstash Redis — opcional) ──────────────────────────────────
# Sin estas vars el rate limit usa memoria por instancia (suficiente en dev).
# Get from: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Flight tracking (proveedor intercambiable) ───────────────────────────────
# aerodatabox (RapidAPI, tier gratis) | flightaware (AeroAPI, pago por consulta)
FLIGHT_PROVIDER=aerodatabox
# Get from: https://rapidapi.com → suscribirse a AeroDataBox plan Basic ($0)
RAPIDAPI_KEY=your-rapidapi-key-here
# Solo si FLIGHT_PROVIDER=flightaware:
FLIGHTAWARE_API_KEY=placeholder

# ── Google Analytics 4 + Search Console (opcionales) ─────────────────────────
# GA4: analytics.google.com → Admin → Data Streams → Measurement ID (G-XXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Search Console: método "Etiqueta HTML" → contenido del meta google-site-verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Vercel Cron ───────────────────────────────────────────────────────────────
# Protege /api/cron/*. Generate with: openssl rand -hex 32
# Vercel lo envía automáticamente como "Authorization: Bearer <CRON_SECRET>"
CRON_SECRET=your-cron-secret-here
