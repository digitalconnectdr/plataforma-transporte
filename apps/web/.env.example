# ──────────────────────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env.local AND FILL IN YOUR REAL VALUES
# NEVER commit .env.local to version control
# ──────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key — NEVER expose to frontend
# Used only in Server Actions and Route Handlers
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Maps ───────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Routes API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-base64-key-here
